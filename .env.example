# Google OAuth — create at console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NextAuth
NEXTAUTH_SECRET=        # generate with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000   # set to your Vercel URL in production

# Google Sheets published as CSV
# File > Share > Publish to web > select sheet > CSV > copy link

# pdf_index sheet (columns: region | center | batch | test_date | pdf_name | gdrive_link)
PDF_INDEX_CSV_URL=

# faculty sheet (columns: faculty_email | faculty_name | batch)
FACULTY_CSV_URL=

# heads sheet (columns: email | role | scope_value)
HEADS_CSV_URL=

# master_map sheet (pre-joined: faculty_email | faculty_name | batch | center | region | ch_email | ...)
MASTER_MAP_CSV_URL=

# activity_log sheet published as CSV (for admin dashboard stats)
ACTIVITY_LOG_CSV_URL=

# Revalidation endpoint secret (any long random string)
REVALIDATE_SECRET=

# Apps Script Web App URL for activity logging (see scripts/appscript-logger.gs)
ACTIVITY_LOG_URL=

# Secret sent in log requests so Apps Script can reject unknown callers
LOG_SECRET=

# Comma-separated admin emails (get access to /admin)
ADMIN_EMAILS=

# Dev only — email to impersonate (must exist in your faculty or heads sheet)
DEV_EMAIL=
