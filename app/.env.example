# Google OAuth — console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NextAuth
NEXTAUTH_SECRET=        # openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000

# ── Google Sheets — publish each tab as CSV ──────────────────────────────────
# File > Share > Publish to web > select tab > CSV > copy link

# pdf_index sheet → pdf_index tab
PDF_INDEX_CSV_URL=

# user_access sheet → faculty tab  (faculty_email | faculty_name | batch)
FACULTY_CSV_URL=

# user_access sheet → heads tab    (email | role | scope_value)
HEADS_CSV_URL=

# user_access sheet → master_map tab  (auto-built by Apps Script)
MASTER_MAP_CSV_URL=

# activity_log sheet → activity_log tab
ACTIVITY_LOG_CSV_URL=

# ── Apps Script Web App ───────────────────────────────────────────────────────
# Handles: activity logging + build_master_map + send_reports
ACTIVITY_LOG_URL=

# Shared secret between Vercel and Apps Script (any random string)
LOG_SECRET=

# ── Revalidation ─────────────────────────────────────────────────────────────
REVALIDATE_SECRET=      # any long random string

# ── Admin access ─────────────────────────────────────────────────────────────
# Comma-separated emails that can access /admin
ADMIN_EMAILS=ranvijay.singh2@pw.live

# Dev only — impersonate a user (faculty email or head email)
DEV_EMAIL=
